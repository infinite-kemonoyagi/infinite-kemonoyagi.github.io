---
import Content from '../components/Content.astro';
import ContentGroup from '../components/ContentGroup.astro';
import Layout from '../layouts/Layout.astro';
---

<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.3/jquery.min.js" defer></script>

<Layout>

	<div id="_main-content">
		<ContentGroup style="width: 50%">
			<Content>
				Hello, I'm Infinite Kemonoyagi :3
				<br>
				I love code and draw cute and weird things xd
				<br> <br>

				I'm developing some cool games right now like:
				<strong> Unlucky dog </strong>
				<strong> The Goats Of The Rock </strong>
				<br>
				Webseries like:
				<strong> Pat's World </strong>
				<br>
				and more
			</Content>
		</ContentGroup>

		<img id="spectator" src="/images/spectator/infinite kemonoyagi.png" alt="Infinite Kemonoyagi, IKY">
	</div>

</Layout>

<style is:global>
	#_main-content {
		align-items: center;
    display: flex;

    overflow: hidden;

		height: calc(100vh - 135px);
	}

	#spectator {
		margin-top: auto;
		margin-bottom: auto;
		margin-left: auto;
    padding-right: 25px;
		height: 75vh;
	}
</style>

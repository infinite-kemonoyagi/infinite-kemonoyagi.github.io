---
interface Props {
  id: string;
  imageSource: string;
  xmlSource: string;
  tex: string;
  width?: number;
  height?: number;
  fps?: number;
  loop?: boolean;
  autoplay?: boolean;
}
const { id, imageSource, xmlSource, tex, width = 100, height = 100, fps = 24, loop = true, autoplay = true } = Astro.props;
---

<canvas class="frame-atlas" id={`${id}`} width={width} height={height}></canvas>

<script>
  import '/source/scripts/SparrowAtlasManager.ts';
</script>

<script is:inline define:vars={{ imageSource, xmlSource, frameName: tex, id, fps, loop, autoplay }} defer>
  async function load() {
    const resource = await fetch(xmlSource);
    const text = await resource.text();
    const parser = new DOMParser();
    const xml = parser.parseFromString(text, "application/xml");

    const allFrames = [];
    for (const data of xml.querySelectorAll("SubTexture")) {
      if (data.getAttribute("name").startsWith(frameName)) {
        allFrames.push({
          x: parseInt(data.getAttribute("x")),
          y: parseInt(data.getAttribute("y")),
          width: parseInt(data.getAttribute("width")),
          height: parseInt(data.getAttribute("height")),
        });
      }
    }

    if (allFrames.length === 0) {
      console.error(`frame ${frameName} doesn't found`);
      return;
    }

    const image = new Image();
    image.src = imageSource;

    image.onload = () => {
      const canvas = document.getElementById(id);
      const ctx = canvas.getContext("2d");

      window.SparrowAtlasManager.current.stored.set(id, canvas);
      window.SparrowAtlasManager.current.storedData.set(id, {
        play: play,
        stop: stop,
        goToFrame: goToFrame,
        setAnimation: setAnimation,
      });

      let currentFrame = 0;
      let intervalId = null;

      function drawFrame(index) {
        const frame = allFrames[index];
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(image, frame.x, frame.y, frame.width, frame.height, 0, 0, canvas.width, canvas.height);
      }

      function play() {
        if (intervalId) return;
        intervalId = setInterval(() => {
          drawFrame(currentFrame);
          if (fps === 0) return;

          currentFrame++;
          if (currentFrame >= allFrames.length) {
            if (loop) currentFrame = 0;
            else stop();
          }
        }, 1000 / fps);
      }

      function stop() {
        clearInterval(intervalId);
        intervalId = null;
      }

      function goToFrame(index) {
        currentFrame = index;
        drawFrame(index);
      }

      function setAnimation(newFrameName) {
        stop();
        const newFrames = [];
        for (const data of xml.querySelectorAll("SubTexture")) {
          if (data.getAttribute("name").startsWith(newFrameName)) {
            newFrames.push({
              x: parseInt(data.getAttribute("x")),
              y: parseInt(data.getAttribute("y")),
              width: parseInt(data.getAttribute("width")),
              height: parseInt(data.getAttribute("height")),
            });
          }
        }

        allFrames.length = 0;
        allFrames.push(...newFrames);
        currentFrame = 0;
        play();
      }

      drawFrame(0);
      if (autoplay && allFrames.length > 1) play();

      window.dispatchEvent(new CustomEvent("sparrow-atlas-canvas-ready", {
        detail: {id}
      }));
    };
  }

  load();

</script>

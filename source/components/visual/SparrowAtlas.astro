---
interface Props {
  id:String;
  imageSource:string;
  xmlSource:string;
  tex:string;
  width?:number;
  height?:number;
}

const { id, imageSource, xmlSource, tex, width = 100, height = 100 } = Astro.props;
---

<canvas class="frame-atlas" id={`${id}`} width={width} height={height}></canvas>

<script is:inline define:vars={{ imageSource, xmlSource, frameName: tex, id }}>

  async function load() {
    const resource = await fetch(xmlSource);
    const text = await resource.text();
    const parser = new DOMParser();

    const xml = parser.parseFromString(text, "application/xml");

    const frames = xml.querySelectorAll("SubTexture");
    let frame = null;

    for (const data of frames) {
      if (data.getAttribute("name").startsWith(frameName)) {
        frame = {
          x: parseInt(data.getAttribute("x")),
          y: parseInt(data.getAttribute("y")),
          width: parseInt(data.getAttribute("width")),
          height: parseInt(data.getAttribute("height")),
        };
        break;
      }
    }

    if (!frame) {
      console.error(`frame ${frameName} doesn't found`);
      return;
    }

    const image = new Image();
    image.src = imageSource;
    image.onload = () => {
      const canvas = document.getElementById(id);
      const context = canvas.getContext("2d");

      context.drawImage(image,
        frame.x, frame.y, frame.width, frame.height,
        0, 0, canvas.width, canvas.height
      );
    };
  }

  load();

</script>

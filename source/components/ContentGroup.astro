---
interface Props {
  id?:String;
  style?:String;
}

const {id, style} = Astro.props;
---

<div class="_content-group" id={`${id}`} style={`${style}`}>
  <slot></slot>
</div>

<style is:global>
  ._content-group {
    background-color: #ccccccec;
    border: 4px solid black;
    border-radius: 2px;

    margin: 25px;

    scroll-padding-left: 10px;
    overflow-y: auto;

    height: calc(92.5vh - 135px);
  }
  ._content-group * {
    margin: 5px;
  }
</style>

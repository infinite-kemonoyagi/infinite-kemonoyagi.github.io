---
import SparrowAtlas from './visual/SparrowAtlas.astro';

interface Props {
  currentPage:string;
}

const {currentPage} = Astro.props;
---

<nav id="_topbar">
  <div class="_topbar-button" id="infinite-button-header">
    <a href="/">
      <SparrowAtlas
        id="infinite-button"
        imageSource="/images/buttons/infinite-kemonoyagi-portal.png"
        xmlSource="/images/buttons/infinite-kemonoyagi-portal.xml"
        tex="Infinite Kemonoyagi Portal"
        width={329}
        height={137}
        fps={0}
        loop={false}
      ></SparrowAtlas>
    </a>
  </div>

  <div class="_topbar-button" id="pages-button-header">
    <SparrowAtlas
      id="pages-button"
      imageSource="/images/buttons/pages.png"
      xmlSource="/images/buttons/pages.xml"
      tex="pages button"
      width={159}
      height={79}
      fps={0}
      loop={false}
    ></SparrowAtlas>
  </div>

  <div class="_topbar-right-group">
    <div class="_topbar-button" id="socials-button-header">
      <SparrowAtlas
        id="socials-button"
        imageSource="/images/buttons/socials.png"
        xmlSource="/images/buttons/socials.xml"
        tex="socials button"
        width={190}
        height={79}
        fps={0}
        loop={false}
      ></SparrowAtlas>
    </div>

    <div class="_topbar-button" id="source-code-button-header">
      <a href="https://github.com/infinite-kemonoyagi/infinite-kemonoyagi.github.io">
        <SparrowAtlas
          id="source-code-button"
          imageSource="/images/buttons/source-code.png"
          xmlSource="/images/buttons/source-code.xml"
          tex="source code button"
          width={71}
          height={72}
          fps={0}
          loop={false}
        ></SparrowAtlas>
      </a>
    </div>

    <div class="_topbar-button" id="information-button-header">
      <SparrowAtlas
        id="information-button"
        imageSource="/images/buttons/information.png"
        xmlSource="/images/buttons/information.xml"
        tex="information button"
        width={71}
        height={72}
        fps={0}
        loop={false}
      ></SparrowAtlas>
    </div>
  </div>

  <div class="_topbar-bottom">
    <div class="_topbar-button" id="toggle-topbar">
      <SparrowAtlas
        id="toggle-topbar-button"
        imageSource="/images/topbar/toggle.png"
        xmlSource="/images/topbar/toggle.xml"
        tex="topbar toggle button"
        width={143}
        height={43}
        fps={0}
        loop={false}
      ></SparrowAtlas>
    </div>
  </div>

</nav>

<div id="_topbar-spacer" style="height: 135px;"></div>

<ul id="topbar-menu-context">

  <li class="topbar-menu-elements" id="arts-page">
    <a href="/arts"> Arts </a>
  </li>

  <li class="topbar-menu-elements" id="archived-page">
    <a href="/archived-old-website"> Archived old version </a>
  </li>

</ul>

<style is:global>
  #_topbar {
    position: fixed;
    top: 0px;
    background-image: url("/images/topbar/background.png");
    height: 135px;
    width: 100vw;

    align-items: center;
    display: flex;

    overflow: hidden;
  }

  #topbar-menu-context {
    position: absolute;
    top: 0px;

    padding: 15px;
    width: max-content;

    background: #a48e9a;
    border: 3px solid black;
    border-radius: 7px;
    visibility: hidden;
    opacity: 0;
  }

  .topbar-menu-elements {
    background: rgb(77, 49, 69);
    border: 2px solid black;
    border-radius: 7px;

    margin-bottom: 15px;

    width: 190px;
    height: max-content;
    list-style: none;
  }
  .topbar-menu-elements::after {
    margin-bottom: 0;
  }

  .topbar-menu-elements a {
    display: flex;
    width: 100%;
    height: 100%;
    margin-left: 5px;
    text-decoration: none;
    color: rgb(255, 255, 255);
  }

  ._topbar-button {
    padding-right: 5px;

    flex-shrink: 0;
  }

  ._topbar-right-group {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 15px;
    padding-right: 10px;
  }

  ._topbar-bottom {
    position: fixed;
    display: inline;
    margin: auto;
    transform: translateY(130%);
    width: 100vw;
  }

  #toggle-topbar {
    width: min-content;
    margin: auto;
  }

  #socials-button-header {
    padding-left: 145px;
  }

  #information-button-header {
    margin-left: auto;
    padding-right: 10px;
    padding-left: 45px;
  }
</style>

<script defer>

  let topbarInterval = null;
  let contextMenuInterval = null;
  let topbarIsHidden = false;

  const topbarContainer = document.getElementById("_topbar");
  const topbarSpacer = document.getElementById("_topbar-spacer");

  const topbarContextMenu = document.getElementById("topbar-menu-context");
  let topbarContextMenuValues = [];

  const topbarButtonPressed = new Map();
  let lastTBButtonPressedName = "";
  let lastTBButtonPressed;
  let lastTBButtonSparrow;

  function updateTopbarSpacer(container) {
    var height = getTopbarSpacerHeight(container);
    topbarSpacer.style.height = `${height}`;
  }

  function getTopbarSpacerHeight(container) {
    var topbarHeight = container.clientHeight;
    return topbarHeight;
  }

  window.addEventListener("sparrow-atlas-canvas-ready", (e) => {
    const sparrowAtlas = window.SparrowAtlasManager.current;
    let name = "";

    switch (e.detail.id) {
      case "infinite-button":
        name = "infinite-button";
        break;

      case "pages-button":
        name = "pages-button";
        break;

      case "socials-button":
        name = "socials-button";
        break;

      case "source-code-button":
        name = "source-code-button";
        break;

      case "information-button":
        name = "information-button";
        break;

      case "toggle-topbar-button":
        name = "toggle-topbar-button";
        updateTopbarSpacer(topbarContainer);
        break;

      default:
        return;
    }
    sparrowAtlas.stored.get(name).addEventListener("mouseover", (e) => {
      sparrowAtlas.goToFrame(name, 2);

      if (name !== "infinite-button" || name !== "source-code-button") {
        sparrowAtlas.stored.get(name).style.cursor = "pointer";
      }
    });
    sparrowAtlas.stored.get(name).addEventListener("mouseout", (e) => {
      if (!topbarButtonPressed.get(name)) sparrowAtlas.goToFrame(name, 0);
    });
    sparrowAtlas.stored.get(name).addEventListener("click", () => {
      switch (name) {
        case "pages-button":
          closeTopbarContextMenu(true);
          openTopbarContextMenu(name, sparrowAtlas.stored.get(name), sparrowAtlas);
          break;
        case "socials-button":
          closeTopbarContextMenu(true);
          openTopbarContextMenu(name, sparrowAtlas.stored.get(name), sparrowAtlas);
          break;

        case "information-button":
          openInformation();
          break;

        case "toggle-topbar-button":
          topbarIsHidden = !topbarIsHidden
          if (topbarIsHidden) hideTopbar(topbarContainer, sparrowAtlas.stored.get(name));
          else showTopbar(topbarContainer, sparrowAtlas.stored.get(name));
          break;

        default:
          return;
      }
    });
  });

  /**
   * @param {HTMLElement} element
   * @param {HTMLElement} toggle
   */
  function hideTopbar(element, toggle) {
    clearInterval(topbarInterval);
    topbarInterval = setInterval(frame, 10);

    var y = parseFloat(getComputedStyle(element).top);
    var defaultHeight = parseFloat(getComputedStyle(topbarContainer).height);
    element.style.position = "fixed";
    element.style.top = `${y}px`;

    var topbarHeight = element.clientHeight;
    var toggleHeight = toggle.clientHeight;
    var height = topbarHeight - toggleHeight + 15;

    function frame() {
      if (y <= -height) {
        clearInterval(topbarInterval);
      } else {
        y += (-height - y) * 0.2;
        topbarSpacer.style.height = `${defaultHeight + (y / 2)}px`;
        element.style.top = `${y}px`;
      }
    }
  }
  /**
   * @param {HTMLElement} element
   */
  function showTopbar(element) {
    clearInterval(topbarInterval);
    topbarInterval = setInterval(frame, 10);

    var y = parseFloat(getComputedStyle(element).top);
    var defaultHeight = getTopbarSpacerHeight(element);
    var spacerHeight = parseFloat(getComputedStyle(topbarSpacer).height);
    element.style.position = "fixed";
    element.style.top = `${y}px`;

    function frame() {
      if (y >= 0 && spacerHeight >= defaultHeight) {
        clearInterval(topbarInterval);
      } else {
        y += -y * 0.2;
        spacerHeight += (defaultHeight - spacerHeight) * 0.2
        element.style.top = `${y}px`;
        topbarSpacer.style.height = `${spacerHeight}px`;
      }
    }
  }

  /**
   * @param {String} name
   * @param {HTMLElement} element
   */
  async function openTopbarContextMenu(name, element, buttonSparrow) {
    topbarButtonPressed.set(name, true);

    lastTBButtonPressed = element;
    lastTBButtonSparrow = buttonSparrow;

    lastTBButtonPressedName = name;

    const realName = name.replace("-button", "");
    const rect = element.getBoundingClientRect();

    await fetch(`/data/topbar/${realName}.json`)
      .then(a => a.json())
      .then(b => (topbarContextMenuValues = b))
      .catch(error => console.error(error));

    if (topbarContextMenu.innerHTML !== "") topbarContextMenu.innerHTML = "";

    console.log(topbarContextMenuValues);

    for (const object of topbarContextMenuValues) {
      topbarContextMenu.innerHTML += `<li class="topbar-menu-elements" id="${object.id}">
        <a href="${object.url}"> ${object.name} </a>
      </li>`;
    }

    topbarContextMenu.style.left = `${rect.left}px`;
    topbarContextMenu.style.top = `${rect.top}px`;
    topbarContextMenu.style.visibility = "visible";
    let top = rect.top;
    const topDest = rect.bottom;
    let opacity = 0.0;
    topbarContextMenu.style.opacity = `${opacity}`;

    clearInterval(contextMenuInterval);
    contextMenuInterval = setInterval(frame, 10);

    function frame() {
      if (top == topDest && opacity == 1.0) {
        clearInterval(contextMenuInterval);
      } else {
        top += (topDest - top) * 0.06;
        opacity += (1 - opacity) * 0.06;
        topbarContextMenu.style.top = `${top}px`;
        topbarContextMenu.style.opacity = `${opacity}`;
      }
    }
  }

  /**
   * @param {bool} fast
   */
  function closeTopbarContextMenu(fast) {
    if (lastTBButtonPressedName === "") return;

    topbarButtonPressed.set(lastTBButtonPressedName, false);

    if (lastTBButtonSparrow) {
      lastTBButtonSparrow.goToFrame(lastTBButtonPressedName, 0);
      lastTBButtonSparrow = null;
    }
    lastTBButtonPressedName = "";

    let top = parseFloat(topbarContextMenu.style.top);
    let opacity = parseFloat(topbarContextMenu.style.opacity);

    clearInterval(contextMenuInterval);

    if (fast) {
      topbarContextMenu.style.opacity = "0";
      topbarContextMenu.style.visibility = "hidden";
      return;
    }

    contextMenuInterval = setInterval(frame, 10);
    function frame() {
      top *= 1.005;
      opacity += -opacity * 0.1;
      topbarContextMenu.style.top = `${top}px`;
      topbarContextMenu.style.opacity = `${opacity}`;
      if (opacity.toFixed(2) == 0) {
        topbarContextMenu.style.visibility = "hidden";
        clearInterval(contextMenuInterval);
      }
    }
  }

  function openInformation() {
    informationContainer.style.opacity = `0`;
		informationBackground.style.opacity = `0`;
		informationParent.style.visibility = `visible`;

    let opacity = 0.0;

    clearInterval(informationInterval);
    informationInterval = setInterval(frame, 10);

    function frame() {
      opacity += (1 - opacity) * 0.1;

      informationContainer.style.opacity = `${opacity}`;
			informationBackground.style.opacity = `${opacity * 0.5}`;

      if (opacity.toFixed(2) == 0) {
        clearInterval(informationInterval);
      }
    }
  }

  document.addEventListener("click", (e) => {
    if (lastTBButtonPressedName === "") return;

    const clickedInsideMenu = topbarContextMenu.contains(e.target);
    const clickedButton = lastTBButtonSparrow && lastTBButtonPressed.contains(e.target);

    if (!clickedInsideMenu && !clickedButton) closeTopbarContextMenu(false);
  });

</script>
